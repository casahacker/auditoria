# ── AI providers ──────────────────────────────────────────────────────────────
# Required: DeepSeek API key for audit analysis (IA)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Required for Google Workspace login.
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Session ────────────────────────────────────────────────────────────────────
# Required: Random secret for signing session cookies. Use a long random string.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Application URL ────────────────────────────────────────────────────────────
# Required: Full public URL of this deployment (no trailing slash).
# Used as the OAuth callback base URL.
APP_URL=https://auditoria.example.org

# ── Azure Document Intelligence (optional) ────────────────────────────────────
# When set, enables Azure DI as the primary PDF extraction engine.
# Set EXTRACTION_ENGINE=azure to activate. Falls back to local (pdftotext + Tesseract) on error.
# Endpoint: Azure AI Foundry resource URL (without trailing slash)
# Example: https://my-resource.services.ai.azure.com
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
EXTRACTION_ENGINE=local

# ── Portal da Transparência / CGU (optional — Diligência de Fornecedores) ──────
# Free per-email token from https://api.portaldatransparencia.gov.br/
# Enables CEIS / CNEP / CEPIM / Acordos de Leniência checks. Sent as the
# "chave-api-dados" header. Without it, the diligence still runs the Receita check.
PORTAL_TRANSPARENCIA_KEY=

# Diligência automática:
# - DILIGENCIA_RATE_PER_MIN: teto de chamadas HTTP às APIs externas por minuto (default 100).
# - DILIGENCIA_SWEEP_MS: intervalo da varredura que enfileira novos/vencidos (default 300000 = 5 min; mín 60000).
# - DILIGENCIA_AUTO: "0" desliga a geração automática (mantém só o botão "Consultar todos").
DILIGENCIA_RATE_PER_MIN=100
DILIGENCIA_SWEEP_MS=300000
DILIGENCIA_AUTO=1

# ── KYS / KYG — Conformidade + assinatura via Documenso (opcional) ──────────────
# A cada envio do wizard, o app GERA um PDF de conformidade já pré-preenchido
# (kycPdf.ts) e o assina pela API do Documenso: cria o documento (POST /documents,
# que devolve uma URL de upload no S3), envia o PDF por PUT, adiciona o campo de
# assinatura no signatário (POST /documents/{id}/fields) e dispara o envio
# (POST /documents/{id}/send). NÃO usa templates nem formValues — o Documenso só
# precisa estar com armazenamento S3 habilitado.
# Setup ÚNICO (no lado do Documenso, documenso.casahacker.org):
#   1. Configure o Documenso com armazenamento S3 (NEXT_PUBLIC_UPLOAD_TRANSPORT=s3).
#   2. Settings → API Tokens → crie um token (vai em DOCUMENSO_API_TOKEN).
# Com o token preenchido, KYS e KYG ficam ambos habilitados. Sem ele, o wizard
# funciona e grava o registro, mas a etapa de assinatura fica desabilitada
# (a ficha é recebida sem assinatura eletrônica).
DOCUMENSO_URL=https://documenso.casahacker.org
DOCUMENSO_API_TOKEN=

# ── Operacional (opcional — normalmente já vem do compose.yaml) ─────────────────
# TZ: fuso das datas nos relatórios (o container roda em UTC).
TZ=America/Sao_Paulo
# SERVER_IP: IP registrado como "solicitante" nas consultas automáticas (trilha auditável).
SERVER_IP=20.206.161.89
# KYC_SIGN_SWEEP_MS: varredura que detecta assinaturas concluídas no Documenso (default 60000 = 1 min).
KYC_SIGN_SWEEP_MS=60000
# DILIGENCIA_FORCE_REFRESH: "1" força a atualização cadastral de toda a base no startup (volte a 0 depois).
DILIGENCIA_FORCE_REFRESH=0
# APP_COMMIT: hash curto do commit, exibido no rodapé/memória do relatório.
#   No build: APP_COMMIT=$(git rev-parse --short HEAD)
APP_COMMIT=

# ── Avançado — overrides das URLs das fontes da diligência ──────────────────────
# Só defina se a URL oficial mudar; por padrão o app usa as oficiais.
# OFAC_SDN_URL=        # OFAC SDN (Tesouro/EUA)
# OFAC_CONS_URL=       # OFAC Consolidated (não-SDN)
# UN_SC_URL=           # Lista consolidada do Conselho de Segurança da ONU
# EU_FSF_URL=          # Sanções financeiras da União Europeia
# UK_SANCTIONS_URL=    # Sanções do Reino Unido (FCDO)
# IDB_URL=             # Sancionados do Banco Interamericano (BID)
# LISTA_SUJA_URL=      # Cadastro de Empregadores / trabalho escravo (MTE)
# TCU_INIDONEOS_URL=   # Licitantes inidôneos (TCU)
# TCE_SP_URL=          # Apenados do TCE-SP
