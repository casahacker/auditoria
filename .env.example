# ── AI providers ──────────────────────────────────────────────────────────────
# Required: DeepSeek API key for audit analysis (IA)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Required for Google Workspace login.
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Session ────────────────────────────────────────────────────────────────────
# Required: Random secret for signing session cookies. Use a long random string.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Application URL ────────────────────────────────────────────────────────────
# Required: Full public URL of this deployment (no trailing slash).
# Used as the OAuth callback base URL.
APP_URL=https://stack-audit.example.org

# ── Azure Document Intelligence (optional) ────────────────────────────────────
# When set, enables Azure DI as the primary PDF extraction engine.
# Set EXTRACTION_ENGINE=azure to activate. Falls back to local (pdftotext + Tesseract) on error.
# Endpoint: Azure AI Foundry resource URL (without trailing slash)
# Example: https://my-resource.services.ai.azure.com
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
EXTRACTION_ENGINE=local
