# ── AI providers ──────────────────────────────────────────────────────────────
# Required: DeepSeek API key for audit analysis (IA)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Required for Google Workspace login.
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Session ────────────────────────────────────────────────────────────────────
# Required: Random secret for signing session cookies. Use a long random string.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Application URL ────────────────────────────────────────────────────────────
# Required: Full public URL of this deployment (no trailing slash).
# Used as the OAuth callback base URL.
APP_URL=https://stack-audit.example.org

# ── Azure Document Intelligence (optional) ────────────────────────────────────
# When set, enables Azure DI as the primary PDF extraction engine.
# Set EXTRACTION_ENGINE=azure to activate. Falls back to local (pdftotext + Tesseract) on error.
# Endpoint: Azure AI Foundry resource URL (without trailing slash)
# Example: https://my-resource.services.ai.azure.com
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
EXTRACTION_ENGINE=local

# ── Portal da Transparência / CGU (optional — Diligência de Fornecedores) ──────
# Free per-email token from https://api.portaldatransparencia.gov.br/
# Enables CEIS / CNEP / CEPIM / Acordos de Leniência checks. Sent as the
# "chave-api-dados" header. Without it, the diligence still runs the Receita check.
PORTAL_TRANSPARENCIA_KEY=

# Diligência automática:
# - DILIGENCIA_RATE_PER_MIN: teto de chamadas HTTP às APIs externas por minuto (default 100).
# - DILIGENCIA_SWEEP_MS: intervalo da varredura que enfileira novos/vencidos (default 300000 = 5 min; mín 60000).
# - DILIGENCIA_AUTO: "0" desliga a geração automática (mantém só o botão "Consultar todos").
DILIGENCIA_RATE_PER_MIN=100
DILIGENCIA_SWEEP_MS=300000
DILIGENCIA_AUTO=1

# ── KYS / KYG — Conformidade + assinatura via Documenso (opcional) ──────────────
# Assinatura por TEMPLATE + formValues (o Documenso aqui usa armazenamento local).
# Setup ÚNICO no Documenso (documenso.casahacker.org):
#   1. Settings → API Tokens → crie um token (vai em DOCUMENSO_API_TOKEN).
#   2. Gere os PDFs-template: `npx tsx scripts/gen-kyc-templates.ts` (saída em kyc-templates/).
#   3. Templates → New Template → suba cada PDF; adicione 1 recipient "Signatário" e
#      1 campo SIGNATURE na área "ASSINADO ELETRONICAMENTE"; salve e copie o templateId.
#   4. Preencha os IDs abaixo e recrie o container.
# Sem estas variáveis, o wizard funciona e grava o registro, mas a etapa de
# assinatura fica desabilitada (a ficha é recebida sem assinatura eletrônica).
DOCUMENSO_URL=https://documenso.casahacker.org
DOCUMENSO_API_TOKEN=
